# ─────────────────────────────────────────────────────────
#  CareCompass Backend — Environment Variables
#  Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # never expose client-side
SUPABASE_ANON_KEY=your-anon-key

# Cohere AI  (translation + EHR extraction + SDTM mapping)
COHERE_API_KEY=your-cohere-key

# Anthropic (Claude — clinical insights + compliance review)
ANTHROPIC_API_KEY=sk-ant-your-key

# Twilio  (SMS reminders in patient's language)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# SendGrid  (email reminders)
SENDGRID_API_KEY=SG.your-key
SENDGRID_FROM_EMAIL=reminders@carecompass.ca

# JWT secret (sign internal service tokens)
JWT_SECRET=change-me-to-a-long-random-string

# Reminder cron schedule (default: every 30 min)
REMINDER_CRON=*/30 * * * *
